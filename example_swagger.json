{
  "swagger": "2.0",
  "info": {
    "title": "Example API",
    "version": "1.0.0",
    "description": "Example API for testing"
  },
  "basePath": "/api/v1",
  "paths": {
    "/users": {
      "post": {
        "operationId": "createUser",
        "summary": "Create a new user",
        "tags": ["users"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {"type": "string"},
                "email": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "201": {"description": "User created"}
        }
      },
      "get": {
        "operationId": "listUsers",
        "summary": "List all users",
        "tags": ["users"],
        "responses": {
          "200": {"description": "Success"}
        }
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user by ID",
        "tags": ["users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Update user",
        "tags": ["users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user",
        "tags": ["users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {"description": "Deleted"}
        }
      }
    },
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create a new order",
        "tags": ["orders"],
        "responses": {
          "201": {"description": "Order created"}
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get order by ID",
        "tags": ["orders"],
        "responses": {
          "200": {"description": "Success"}
        }
      }
    }
  }
}
