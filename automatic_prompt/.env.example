# ==========================================
# Automatic Prompt Optimization 环境配置
# ==========================================
#
# 使用说明：
# 1. 复制此文件并重命名为 .env
# 2. 填写你的实际API密钥和配置
# 3. 不要将 .env 文件提交到版本控制
#
# 示例：
# cp .env.example .env
#

# ==========================================
# 千问（Qwen）API 配置
# ==========================================
# 从这里获取 API Key: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_api_key_here

# 模型选择
# 可选值: qwen-max, qwen-plus, qwen-turbo
QWEN_MODEL=qwen-max

# 生成参数
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=500

# ==========================================
# OpenAI API 配置（可选）
# ==========================================
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4
# OPENAI_TEMPERATURE=0.7

# ==========================================
# Anthropic API 配置（可选）
# ==========================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# ==========================================
# 优化配置
# ==========================================
# MAX_ITERATIONS=10
# NUM_CANDIDATES=5
# TOP_K=3
